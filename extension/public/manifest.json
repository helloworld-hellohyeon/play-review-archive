{
  "manifest_version": 3,
  "name": "이매지너리 Thread Archive",
  "version": "0.0.1",
  "description": "Twitter/X 스레드를 ZIP으로 추출합니다",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://twitter.com/*", "https://x.com/*", "https://pbs.twimg.com/*"],
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
