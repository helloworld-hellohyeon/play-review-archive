{
  "name": "thread-archive-extension",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "npm run clean && npm run build:content && npm run build:popup",
    "build:content": "vite build --config vite.config.content.ts",
    "build:popup": "vite build --config vite.config.popup.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2"
  }
}
